# Copy this file to .env and fill in real values.
# .env is gitignored and should never be committed.
# Canonical contract: ServiceName__Section__Key with uppercase ENV segments.

# Kraken API Keys (required for private data like balance/positions)
MARKETDATA__KRAKEN__APIKEY=
MARKETDATA__KRAKEN__APISECRET=
MARKETDATA__EXCHANGE__USEMOCK=false

# Agent Runner
AGENTRUNNER__TOOLS__BRAVESEARCH__APIKEY=
AGENTRUNNER__API__APIKEY=

# Execution Service
EXECUTIONSERVICE__API__APIKEY=
EXECUTIONSERVICE__KRAKEN__APIKEY=
EXECUTIONSERVICE__KRAKEN__APISECRET=
EXECUTIONSERVICE__MARKETDATASERVICEURL=http://localhost:5002

# Monitoring Dashboard
MONITORINGDASHBOARD__AGENTRUNNER__URL=http://localhost:5003
MONITORINGDASHBOARD__AGENTRUNNER__APIKEY=
MONITORINGDASHBOARD__EXECUTIONSERVICE__URL=http://localhost:5004
MONITORINGDASHBOARD__MARKETDATASERVICE__URL=http://localhost:5002
