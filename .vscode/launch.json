{
    "version": "0.2.0",
    "configurations": [
        // ── AgentRunner ────────────────────────────────────────────────
        {
            "name": "Debug Crypton.Api.AgentRunner",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build: Crypton.Api.AgentRunner",
            "program": "${workspaceFolder}/src/Crypton.Api.AgentRunner/bin/Debug/net10.0/Crypton.Api.AgentRunner.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/Crypton.Api.AgentRunner",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
                "uriFormat": "%s/scalar/v1"
            },
            "envFile": "${env:HOME}/.config/crypton/.env",
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
        },
        {
            "name": "Debug Crypton.Api.AgentRunner (No Build)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/Crypton.Api.AgentRunner/bin/Debug/net10.0/Crypton.Api.AgentRunner.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/Crypton.Api.AgentRunner",
            "stopAtEntry": false,
            "envFile": "${env:HOME}/.config/crypton/.env",
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        },
        {
            "name": "Debug Crypton.Api.AgentRunner (CLI)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build: Crypton.Api.AgentRunner",
            "program": "${workspaceFolder}/src/Crypton.Api.AgentRunner/bin/Debug/net10.0/Crypton.Api.AgentRunner.dll",
            "args": ["--cli", "run-cycle", "--verbose"],
            "cwd": "${workspaceFolder}/src/Crypton.Api.AgentRunner",
            "stopAtEntry": false,
            "console": "integratedTerminal",
            "envFile": "${env:HOME}/.config/crypton/.env",
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        },
        {
            "name": "Attach to Crypton.Api.AgentRunner",
            "type": "coreclr",
            "request": "attach",
            "processName": "Crypton.Api.AgentRunner"
        },

