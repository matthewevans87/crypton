{
    "executionService": {
        "kraken": {
            "wsBaseUrl": "wss://ws.kraken.com/v2",
            "restBaseUrl": "https://api.kraken.com",
            "maxReconnectAttempts": 5,
            "reconnectDelaySeconds": 2
        },
        "paperTrading": {
            "initialBalanceUsd": 10000,
            "slippagePct": 0.001,
            "commissionRate": 0.0026,
            "statePath": "artifacts/paper_state.json"
        },
        "strategy": {
            "watchPath": "artifacts/strategy.json",
            "reloadLatencyMs": 5000,
            "onLoadTriggerMode": "fresh_crossing",
            "enableFileWatcher": true,
            "enableRestEndpoint": true
        },
        "safety": {
            "consecutiveFailureThreshold": 3,
            "dmsTimeoutSeconds": 60,
            "dmsCheckIntervalSeconds": 5
        },
        "logging": {
            "eventLogPath": "logs/execution_events.ndjson",
            "rotateDaily": true,
            "retainFiles": 7
        },
        "streaming": {
            "metricsUpdateHz": 1
        }
    }
}