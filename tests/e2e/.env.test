# E2E test environment — committed with non-secret test values.
# DO NOT use these values in production.

# Shared API key used by AgentRunner and ExecutionService in test mode.
TEST_API_KEY=testkey

# Service base URLs (defaults, override if you bind to different ports)
MARKET_DATA_URL=http://localhost:5002
EXECUTION_SERVICE_URL=http://localhost:5004
AGENT_RUNNER_URL=http://localhost:5003
MONITORING_DASHBOARD_URL=http://localhost:5001
DASHBOARD_UI_URL=http://localhost:3000

# Set to "true" to have Playwright global setup launch and manage services.
# Leave unset (or false) when you start services yourself with start-test-services.sh.
TEST_MANAGED_SERVICES=false
